<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Dağıtım yöntemi: app-store = TestFlight + App Store -->
    <key>method</key>
    <string>app-store</string>

    <!-- Otomatik imzalama — Xcode senin takımını ve sertifikanı kendisi seçer -->
    <key>signingStyle</key>
    <string>automatic</string>

    <!-- App Store Connect'e direkt yükle (Organizer'da "Upload" yapmana gerek kalmaz) -->
    <key>destination</key>
    <string>upload</string>

    <!-- dSYM sembol dosyaları — crash report için gerekli -->
    <key>uploadSymbols</key>
    <true/>

    <!-- Bitcode kaldırıldı (Xcode 14+ varsayılan) -->
    <key>uploadBitcode</key>
    <false/>

    <!-- Uygulama versiyonu sıkıştırma: Apple dSYM'i kendin yönet -->
    <key>compileBitcode</key>
    <false/>
</dict>
</plist>
