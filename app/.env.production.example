# Nuveli — Production Environment Template
#
# Kullanım:
#   1. Bu dosyayı .env.production olarak kopyala
#   2. Aşağıdaki değerleri gerçek production değerleriyle doldur
#   3. flutter run --dart-define-from-file=.env.production ile çalıştır
#      veya flutter build için --dart-define'larla geçir
#
# GÜVENLİK:
#   - .env.production dosyası ASLA git'e commit edilmemeli (.gitignore'da)
#   - Secret key'leri CI/CD secrets'tan enjekte et (GitHub Actions secrets)
#   - ANON_KEY public'tir ama SERVICE_ROLE_KEY backend-only

# ----------------------------------------------------------------------------
# Environment
# ----------------------------------------------------------------------------
APP_ENV=production
API_BASE_URL=https://api.nuveli.com

# ----------------------------------------------------------------------------
# Supabase (public anon key — frontend-safe)
# ----------------------------------------------------------------------------
SUPABASE_URL=https://your-prod-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...prod-anon-key

# ----------------------------------------------------------------------------
# RevenueCat (platform-specific, public-safe)
# ----------------------------------------------------------------------------
# Apple: https://app.revenuecat.com → Project Settings → API Keys → Apple
RC_APPLE_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx

# Google: https://app.revenuecat.com → Project Settings → API Keys → Google
RC_GOOGLE_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# Sentry / Crashlytics (opsiyonel, ama prod'da önerilir)
# ----------------------------------------------------------------------------
# SENTRY_DSN=https://xxx@sentry.io/yyyy
