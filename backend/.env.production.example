# Nuveli Backend — Production Environment Template
#
# Kullanım:
#   1. Bu dosyayı .env.production olarak kopyala
#   2. Değerleri doldur
#   3. Deployment platformunda (Render, Railway, Fly.io, vs.) environment
#      variables olarak ekle — dosya olarak deploy etme
#
# GÜVENLİK:
#   - .env.production ASLA git'e commit edilmemeli
#   - JWT_SECRET ve SERVICE_ROLE_KEY çok hassas — sadece secure vault'ta
#   - OPENAI_API_KEY rate limit'i düşükse hızla tükenir → monitoring şart

# ============================================================================
# Application
# ============================================================================
APP_ENV=production
PORT=8000
# CORS: virgülle ayrılmış, sadece prod frontend domain'leri
ALLOWED_ORIGINS=https://nuveli.com,https://app.nuveli.com

# ============================================================================
# Supabase
# ============================================================================
SUPABASE_URL=https://your-prod-project.supabase.co

# Public anon key (frontend de kullanır)
SUPABASE_ANON_KEY=eyJhbGci...anon...

# Service role — ASLA frontend'e gitmesin, backend admin operasyonları için
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...service-role...

# JWT signing secret — Supabase Settings → API → JWT Secret'tan al
SUPABASE_JWT_SECRET=super-long-jwt-secret-from-supabase-dashboard

# ============================================================================
# OpenAI
# ============================================================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
# Aylık bütçe limiti için organization ayarlarını dashboard'dan set et
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# ============================================================================
# RevenueCat webhook
# ============================================================================
# https://app.revenuecat.com → Project Settings → Integrations → Webhooks
REVENUECAT_WEBHOOK_SECRET=rc-webhook-secret

# ============================================================================
# Rate limits (free tier için)
# ============================================================================
FREE_MEAL_ANALYSES_PER_DAY=3
FREE_COACH_MESSAGES_PER_DAY=10

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
# Sentry opsiyonel
# SENTRY_DSN=https://xxx@sentry.io/yyyy
