# Nuveli Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# --- App ---
APP_ENV=development           # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=*                # comma-separated origins; "*" for dev only

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...service_role_key
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase

# --- OpenAI ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_VISION=gpt-4o
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# --- RevenueCat (optional in dev) ---
# Set webhook URL in RevenueCat dashboard to:
#   https://your-domain/premium/webhook
# Get from: RevenueCat Dashboard → Project Settings → Integrations → Webhooks
REVENUECAT_WEBHOOK_SECRET=your-webhook-bearer-token

# --- Sentry (optional) ---
# SENTRY_DSN=https://...@sentry.io/...
