# Web app environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# RevenueCat Web Billing — public key (safe in production)
VITE_REVENUECAT_PUBLIC_KEY=your_rcb_public_key_here

# Supabase — anon key (safe in frontend; RLS protects data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Nuveli Pro entitlement identifier
# Must match the identifier configured in RevenueCat dashboard
VITE_RC_ENTITLEMENT_ID=nuveli_pro
